% Background and colors
\setbeamercolor{normal text}{bg=white,fg=black}
\setbeamercolor{structure}{fg=bauhausblue}
\setbeamercolor{frametitle}{bg=bauhausblue,fg=white}
\setbeamercolor{footline}{bg=bauhausblue,fg=white}

\setbeamertemplate{navigation symbols}{}


% Top progress bar
\setbeamertemplate{headline}{%
  \begin{beamercolorbox}[wd=\paperwidth,ht=1.5pt,dp=0pt,leftskip=0pt,rightskip=0pt]{frametitle}%
  \rule{\paperwidth}{1.5pt}%
  \end{beamercolorbox}%
}

% Bottom footline
\setbeamertemplate{footline}{%
  \leavevmode%
  \hbox{%
  	\begin{beamercolorbox}[wd=.33\paperwidth,ht=2.5ex,dp=1ex,leftskip=4ex]{author in head/foot}%
  		\usebeamerfont{author in head/foot}\insertshortauthor%
  	\end{beamercolorbox}%
  	
